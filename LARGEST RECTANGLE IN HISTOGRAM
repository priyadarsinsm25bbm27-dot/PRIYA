#include <vector>
#include <stack>
#include <algorithm>

using namespace std;

class Solution {
public:
    int largestRectangleArea(vector<int>& heights) {
        int n = heights.size();
        stack<int> st;
        int max_area = 0;

        for (int i = 0; i <= n; i++) {
            // Use 0 height at the end to flush the remaining bars in the stack
            int current_height = (i == n) ? 0 : heights[i];

            while (!st.empty() && heights[st.top()] >= current_height) {
                int h = heights[st.top()];
                st.pop();
                
                // If stack is empty, the width extends to the start of the histogram
                int w = st.empty() ? i : i - st.top() - 1;
                
                max_area = max(max_area, h * w);
            }
            st.push(i);
        }

        return max_area;
    }
};
